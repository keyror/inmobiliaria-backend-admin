APP_DOMAIN=
APP_DOMAIN_REGEX=
BACKEND_APP_URL=https
BACKEND_APP_ENV=production
BACKEND_APP_DEBUG=false
BACKEND_APP_KEY=base64:

DB_CONNECTION=
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=
BACKEND_CORS_ALLOWED_ORIGINS=

TRAEFIK_ACME_EMAIL=tu-email@gmail.com

MYSQL_INNODB_BUFFER_POOL_SIZE=64M
MYSQL_INNODB_REDO_LOG_CAPACITY=16777216
MYSQL_INNODB_FLUSH_METHOD=fsync
MYSQL_INNODB_FLUSH_LOG_AT_TRX_COMMIT=2
MYSQL_MAX_CONNECTIONS=20
MYSQL_TABLE_OPEN_CACHE=200
MYSQL_MAX_ALLOWED_PACKET=16M
MYSQL_PERFORMANCE_SCHEMA=OFF

BACKEND_IMAGE=
NGINX_STORAGE_IMAGE=
FRONTEND_ADMIN_IMAGE=
FRONTEND_PUBLIC_IMAGE=


# Cache / Redis
REDIS_CLIENT=predis
CACHE_STORE=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# phpMyAdmin basic auth (generar con: htpasswd -nb usuario contraseña)
# Ejemplo root/root → PMA_BASIC_AUTH=root:$$apr1$$xyz...
PMA_BASIC_AUTH=
